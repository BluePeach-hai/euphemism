#!/usr/bin/env python

# 添加当前目录到Python路径，确保能够找到euphemism模块
import sys
import os.path as osp

# 获取脚本所在目录的父目录（项目根目录）
project_root = osp.abspath(osp.join(__file__, '../..'))
sys.path.insert(0, project_root)

import os
import json
import click


from euphemism.util import preprocess_path



ROOT = osp.abspath(osp.join(osp.dirname(osp.abspath(__file__)), '..'))
DATA_ROOT = osp.join(ROOT, 'data')


@click.command()
@click.option(
    '--data-file',
    type=click.Path(exists=True, file_okay=True), 
    default=osp.join(DATA_ROOT, 'dataset_text.json'),
)
@click.option(
    '--answers-file',
    type=click.Path(exists=True, file_okay=True),
    required=True,
)
@click.option(
    '--terms-file',
    type=click.Path(exists=True, file_okay=True),
    default=osp.join(DATA_ROOT, 'terms.tsv'),
)
@click.option(
    '--term',
    type=str,
    default='大麻',
)
@click.option(
    '--threshold',
    type=float,
    default=0.5,
    help='概率值转换为标签的阈值',
)
def main(data_file, answers_file, terms_file, term, threshold):
    data_file = preprocess_path(data_file)
    answers_file = preprocess_path(answers_file)
    terms_file = preprocess_path(terms_file)

    # 加载数据集
    print(f"\n1. 加载数据集: {data_file}")
    try:
        with open(data_file, 'r', encoding='utf-8') as f:
            data = json.load(f)
        
        # 确保数据是列表格式
        if isinstance(data, dict) and 'List' in data:
            data = data['List']
        
        if not isinstance(data, list):
            print("   错误：数据集格式不正确，应该是列表格式")
            return
            
        data_len = len(data)
        print(f"   加载成功，共 {data_len} 条数据")
        
    except Exception as e:
        print(f"   加载数据集失败: {e}")
        return

    # 加载预测结果
    print(f"\n2. 加载预测结果: {answers_file}")
    print(f"   阈值设置为: {threshold}")
    
    idx_to_label = {} 
    
    try:
        with open(answers_file, 'r', encoding='utf-8') as f:
            lines = f.readlines()
        
        total_lines = len(lines)
        print(f"   读取到 {total_lines} 行数据")
        
        for line_num, line in enumerate(lines):
            line = line.strip()
            if not line:
                continue
                
            l = line.split(',')
            if len(l) != 2:
                continue
                
            try:
                idx = int(l[0])
                value = float(l[1])
                
                # 只处理在数据范围内的索引
                if 0 <= idx < data_len:
                    label = 1 if value >= threshold else 0
                    idx_to_label[idx] = label
                elif idx >= data_len:
                    print(f"   跳过超出数据范围的索引: {idx} (数据长度: {data_len})")
                
            except ValueError as e:
                continue
        
        valid_count = len(idx_to_label)
        print(f"   预测结果加载完成，共 {valid_count} 个有效标签")
        
    except Exception as e:
        print(f"   加载预测结果失败: {e}")
        return

    # 将预测结果与数据匹配
    print(f"\n3. 匹配预测结果与数据")
    matched_count = 0
    for idx, item in enumerate(data):
        if idx in idx_to_label:
            item['answer'] = idx_to_label[idx]
            matched_count += 1
    
    print(f"   匹配完成，共 {matched_count} 条数据匹配到预测结果")

    # 加载术语表
    terms = dict()
    if osp.exists(terms_file):
        print(f"\n4. 加载术语表: {terms_file}")
        try:
            with open(terms_file, 'r', encoding='utf-8') as f:
                lines = f.readlines()
                
            for i, line in enumerate(lines):
                if i == 0:  # 跳过表头
                    continue
                    
                line = line.strip()
                if not line:
                    continue
                    
                l = line.split('\t')
                if len(l) < 2:
                    continue
                    
                term_key, defn = l[0], l[1]
                terms[term_key.strip()] = defn.strip()
            
            print(f"   术语表加载完成，共 {len(terms)} 个术语")
            
        except Exception as e:
            print(f"   读取术语文件失败: {e}")
            terms = dict()
    else:
        print(f"\n4. 术语文件 {terms_file} 不存在，将使用数据中出现的术语")
        terms = dict()

    # 计算性能指标
    print(f"\n5. 计算性能指标...")
    TPs, TNs, FPs, FNs = {}, {}, {}, {}
    # 添加整体统计变量
    total_tp, total_tn, total_fp, total_fn = 0, 0, 0, 0
    total_processed = 0
    
    for idx, item in enumerate(data):
        # 检查必要字段是否存在
        if 'is_drug_related' not in item or 'answer' not in item:
            continue
            
        # 使用 is_drug_related 作为真实标签，而不是 label
        true_label = item['is_drug_related']
        pred_label = item['answer']
        
        # 获取术语
        term_key = None
        for field in ['original_keyword', 'final_keyword', 'keywords']:
            if field in item and item[field]:
                term_key = item[field]
                break
        
        # 如果没有找到术语，使用 'unknown'
        if not term_key:
            term_key = 'unknown'
        
        total_processed += 1
        
        # 更新统计
        if true_label == 1 and pred_label == 1:
            TPs[term_key] = 1 + TPs.get(term_key, 0)
            total_tp += 1
        elif true_label == 0 and pred_label == 0:
            TNs[term_key] = 1 + TNs.get(term_key, 0)
            total_tn += 1
        elif true_label == 0 and pred_label == 1:
            FPs[term_key] = 1 + FPs.get(term_key, 0)
            total_fp += 1
        elif true_label == 1 and pred_label == 0:
            FNs[term_key] = 1 + FNs.get(term_key, 0)
            total_fn += 1
    
    print(f"   共处理 {total_processed} 条有效数据")
    
    # 计算整体准确率和其他指标
    if total_processed > 0:
        # 准确率: (TP + TN) / (TP + TN + FP + FN)
        accuracy = round(100 * (total_tp + total_tn) / total_processed, 2)
        
        # 整体精确率
        overall_precision = 0.0
        if (total_tp + total_fp) > 0:
            overall_precision = round(100 * total_tp / (total_tp + total_fp), 2)
        
        # 整体召回率
        overall_recall = 0.0
        if (total_tp + total_fn) > 0:
            overall_recall = round(100 * total_tp / (total_tp + total_fn), 2)
        
        # 整体F1值
        overall_f1 = 0.0
        if (overall_precision + overall_recall) > 0:
            overall_f1 = round(2 * (overall_precision * overall_recall) / (overall_precision + overall_recall), 2)
        
        print(f"\n   整体性能指标:")
        print(f"   准确率: {accuracy}%")
        print(f"   精确率: {overall_precision}%")
        print(f"   召回率: {overall_recall}%")
        print(f"   F1值: {overall_f1}%")
        print(f"   TP: {total_tp}, TN: {total_tn}, FP: {total_fp}, FN: {total_fn}")
    
    # 计算每个术语的指标
    results = []
    all_terms = set(terms.keys()) | set(TPs.keys()) | set(TNs.keys()) | set(FPs.keys()) | set(FNs.keys())
    
    for term_key in all_terms:
        TP = TPs.get(term_key, 0)
        TN = TNs.get(term_key, 0)
        FP = FPs.get(term_key, 0)
        FN = FNs.get(term_key, 0)
        
        # 计算精确率
        precision = 0.0
        if TP + FP > 0:
            precision = round(100 * TP / (TP + FP), 2)
        
        # 计算召回率
        recall = 0.0
        if TP + FN > 0:
            recall = round(100 * TP / (TP + FN), 2)
        
        # 计算F1值
        f1 = 0.0
        if precision + recall > 0:
            f1 = round(2 * (precision * recall) / (precision + recall), 2)
        
        total = TP + TN + FP + FN
        if total > 0:
            # 获取术语定义，如果没有则使用默认值
            defn = terms.get(term_key, "未知术语")
            results.append((term_key, defn, precision, recall, f1, total))
    
    # 按F1值排序
    results.sort(key=lambda x: x[4])

    # 输出结果
    print("\n6. 性能指标（按F1值排序）：")
    print("=" * 120)
    
    if not results:
        print("   没有足够的数据计算性能指标")
    else:
        for k, d, p, r, F1, N in results:
            print(f'术语: {k} \t 定义: {d} \t 精确率 = {p}, 召回率 = {r}, F1值 = {F1} \t 数量: {N}')

    # 分析特定术语的错误案例
    print(f"\n\n7. 分析特定术语: {term}")
    print("=" * 100)
    
    # 查找相关条目
    subset = []
    for item in data:
        for field in ['original_keyword', 'final_keyword', 'keywords']:
            if field in item and item[field] == term:
                subset.append(item)
                break
    
    print(f"   找到 {len(subset)} 条包含术语 '{term}' 的数据")
    
    fps, fns = [], []
    for x in subset:
        if 'is_drug_related' not in x or 'answer' not in x:
            continue
            
        true_label = x['is_drug_related']
        pred_label = x['answer']
        
        if true_label == 0 and pred_label == 1:
            fps.append(x)
        if true_label == 1 and pred_label == 0:
            fns.append(x)
    
    print(f"   假阳性案例 ({len(fps)} 个):")
    for i, x in enumerate(fps[:10]):
        idx = x.get('index', 'N/A')
        text = x.get('text', 'N/A')
        print(f'   {i+1}. 索引: {idx}, 文本: {text}')
    
    print(f"\n   假阴性案例 ({len(fns)} 个):")
    for i, x in enumerate(fns[:10]):
        idx = x.get('index', 'N/A')
        text = x.get('text', 'N/A')
        print(f'   {i+1}. 索引: {idx}, 文本: {text}')

    print(f"\n\n分析完成！")



if __name__ == "__main__":
    main()